{
    "private": true,
    "type": "module",
    "name": "dash",
    "version": "0.0.0",
    "scripts": {
        "build": "bun run build-pre && tauri build",
        "build-pre": "bun ./scripts/build-pre.ts",
        "dev": "tauri dev",
        "dev-release": "tauri dev --release --no-dev-server",
        "prepare": "bun x --bun svelte-kit sync",
        "tauri": "tauri",
        "vite": "vite",
        "ui:build": "bun x --bun vite build",
        "ui:check": "bun x --bun svelte-check --tsconfig ./tsconfig.json",
        "ui:check-watch": "nodemon --verbose --watch src --ext \"ts,svelte\" --exec \"bun x --bun svelte-check --tsconfig ./tsconfig.json\"",
        "ui:dev": "bun x --bun vite --host 0.0.0.0",
        "ui:preview": "bun x --bun vite preview"
    },
    "devDependencies": {
        "@fontsource/noto-sans-jp": "5.2.9",
        "@humanspeak/svelte-markdown": "^1.0.2",
        "@omujs/chat": "workspace:*",
        "@omujs/i18n": "workspace:*",
        "@omujs/omu": "workspace:*",
        "@omujs/obs": "workspace:*",
        "@omujs/ui": "workspace:*",
        "@sveltejs/adapter-static": "3.0.10",
        "@sveltejs/kit": "2.53.2",
        "@sveltejs/vite-plugin-svelte": "7.0.0",
        "@tabler/icons-webfont": "^3.37.1",
        "@tauri-apps/api": "2.10.1",
        "@tauri-apps/cli": "2.10.0",
        "@tauri-apps/plugin-cli": "^2.4.1",
        "@tauri-apps/plugin-fs": "2.4.5",
        "@tauri-apps/plugin-log": "^2.8.0",
        "@tauri-apps/plugin-opener": "2.5.3",
        "@tauri-apps/plugin-process": "2.3.1",
        "@tauri-apps/plugin-store": "^2.4.2",
        "@tauri-apps/plugin-updater": "2.10.0",
        "@tsconfig/svelte": "5.0.8",
        "@types/dom-speech-recognition": "^0.0.7",
        "@types/license-checker": "25.0.6",
        "esm-env": "1.2.2",
        "license-checker": "25.0.1",
        "sass": "^1.97.3",
        "sugarss": "5.0.1",
        "svelte": "5.53.5",
        "svelte-check": "^4.4.3",
        "tslib": "2.8.1",
        "vite": "7.3.1",
        "vitest": "4.0.18"
    }
}
