{
    "$schema": "../gen/schemas/desktop-schema.json",
    "identifier": "webview",
    "description": "Webview capability for OMUAPPS Dashboard",
    "local": true,
    "windows": [
        "webview-*"
    ],
    "webviews": [
        "webview-*"
    ],
    "remote": {
        "urls": [
            "http://*:*",
            "https://*:*"
        ]
    },
    "permissions": [
        "core:event:allow-emit",
        "core:window:allow-start-resize-dragging",
        "core:window:allow-start-dragging"
    ]
}
