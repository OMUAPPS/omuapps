{
    "private": true,
    "type": "module",
    "name": "site",
    "version": "0.9.48",
    "scripts": {
        "build": "bun run build-pre && bun x --bun vite build",
        "build-pre": "bun ./scripts/build-pre.ts",
        "check": "bun x --bun svelte-kit sync && bun x --bun svelte-check --tsconfig ./tsconfig.json",
        "check:watch": "nodemon --verbose --watch src --ext \"ts,svelte\" --exec \"bun x --bun svelte-check --tsconfig ./tsconfig.json\"",
        "dev": "bun build-pre && bun x --bun vite dev",
        "prepare": "bun x --bun svelte-kit sync",
        "preview": "bun x --bun vite preview",
        "test": "vitest"
    },
    "devDependencies": {
        "@2ji-han/kuromoji.js": "^0.1.8",
        "@fontsource/noto-sans-jp": "^5.2.9",
        "@fontsource/rocknroll-one": "^5.2.8",
        "@humanspeak/svelte-markdown": "^1.0.2",
        "@omujs/chat": "workspace:*",
        "@omujs/i18n": "workspace:*",
        "@omujs/obs": "workspace:*",
        "@omujs/omu": "workspace:*",
        "@omujs/ui": "workspace:*",
        "@sveltejs/adapter-cloudflare": "7.2.8",
        "@sveltejs/kit": "2.53.2",
        "@sveltejs/vite-plugin-svelte": "^7.0.0",
        "@tabler/icons-webfont": "^3.37.1",
        "@types/dom-speech-recognition": "^0.0.7",
        "@types/dom-webcodecs": "^0.1.18",
        "@types/pako": "^2.0.4",
        "@types/seedrandom": "^3.0.8",
        "@types/youtube": "0.1.2",
        "buffer": "^6.0.3",
        "domhandler": "^5.0.3",
        "esm-env": "^1.2.2",
        "htmlparser2": "^10.1.0",
        "pako": "^2.1.0",
        "postcss-html": "^1.8.1",
        "qrious": "^4.0.2",
        "sass": "^1.97.3",
        "seedrandom": "^3.0.5",
        "svelte": "^5.53.5",
        "svelte-check": "^4.4.3",
        "svelte-highlight": "^7.9.0",
        "tslib": "^2.8.1",
        "vite": "^7.3.1",
        "vitest": "^4.0.18"
    }
}
