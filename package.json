{
    "name": "omuapps",
    "type": "module",
    "version": "0.0.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/OMUAPPS/omuapps.git"
    },
    "workspaces": [
        "packages-js/*"
    ],
    "private": true,
    "scripts": {
        "prepare": "bun ./scripts/js-patch.ts",
        "wrangler": "wrangler",
        "build": "bun ./scripts/js-build.ts",
        "build-site": "bun run --cwd packages-js/site build",
        "build-tauri": "bun run --cwd packages-js/dash build",
        "publish": "bun ./scripts/js-publish.ts",
        "clean": "bun ./scripts/js-clean.ts",
        "eslint": "eslint"
    },
    "devDependencies": {
        "@actions/github": "^9.0.0",
        "@eslint/js": "^10.0.1",
        "@stylistic/eslint-plugin": "^5.9.0",
        "@sveltejs/adapter-cloudflare": "^7.2.8",
        "@sveltejs/package": "2.5.7",
        "@types/bun": "1.3.9",
        "@types/eslint": "^9.6.1",
        "@types/node": "^25.3.1",
        "@typescript/native-preview": "^7.0.0-dev.20260225.1",
        "bun-plugin-isolated-decl": "^0.2.9",
        "esbuild": "^0.27.3",
        "eslint": "^10.0.2",
        "eslint-plugin-svelte": "3.15.0",
        "glob": "^13.0.6",
        "globals": "17.3.0",
        "jiti": "^2.6.1",
        "lerna": "^9.0.4",
        "nodemon": "^3.1.14",
        "svelte-eslint-parser": "^1.5.1",
        "typescript": "^5.9.3",
        "typescript-eslint": "8.56.1",
        "wrangler": "4.68.1"
    }
}
